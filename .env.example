# Copy to .env and fill in to use the real OpenAI embedding provider.
# Without a key, the curation pipeline falls back to the deterministic dev-stub
# provider (see src/curation/embedding/DevStubProvider.ts): it lets the whole
# pipeline run offline for plumbing/preview, but its "embeddings" are NOT
# semantically meaningful — the beloved->reviled ranking will be arbitrary.
OPENAI_API_KEY=

# Optional overrides (defaults shown):
# EMBEDDING_PROVIDER=openai        # openai | devstub  (auto: openai if key present, else devstub)
# EMBEDDING_MODEL=text-embedding-3-large
