# Copy to .env and fill in to use the real OpenAI embedding provider.
# Embeddings are curation-time only; the show/runtime reads config.json and
# needs no API. Implementations should fall back to a deterministic offline
# stub when no key is set (plumbing only — stub rankings are not meaningful).
OPENAI_API_KEY=

# Optional overrides (defaults shown):
# EMBEDDING_PROVIDER=openai        # openai | devstub  (auto: openai if key present, else devstub)
# EMBEDDING_MODEL=text-embedding-3-large
